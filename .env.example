# انسخ الملف إلى .env وعدّل القيم
#
# نطاقات UA/EGY الافتراضية (يُكمّلها ملف data/qr-extra-counts.json من لوحة الأدمن)
# QR_UA_START=4110
# QR_UA_BASE_COUNT=75
# QR_EGY_START=5105
# QR_EGY_BASE_COUNT=95
#
# لو ضبطت SEED_SLOT_RANGES يدوياً فهو يتقدّم على الملف أعلاه عند npm run seed:
# SEED_SLOT_RANGES=4110:75,5105:95
#
# لو لم تضبط SEED_SLOT_RANGES: يُستخدم عدد متتالي من 1
# SEED_CODE_COUNT=500

DASHBOARD_USER=admin
DASHBOARD_PASS=ضع_كلمة_سر_قوية_هنا

# روابط داخل الـ QR و manifest — نفس عنوان الموقع العام (https). بدونها seed يستخدم 127.0.0.1
PUBLIC_URL=https://اسم-الخدمة.onrender.com

# اختياري (Render + قرص دائم): نفس mountPath للقرص في لوحة Render، مثلاً /var/data
# DATA_DIR=/var/data

# مولّد الليبلز (Burgundy): مسار مطلق بعد npm run generate-labels من مشروع الموقع
# QR_LABELS_DIR=/Users/dozzy/Desktop/QR-Burgundy-Labels

# تخصيص شريط الليبلز (اختياري — نفس القيم الافتراضية في Burgundy)
# الرقم الظاهر على الليبل = رقم السلوت (4110، 5105، …)
# LABEL_WEDDING_TITLE=FAISAL & TALEED'S WEDDING
# LABEL_LOCATION_EN=Sofitel Cairo Downtown Nile - Cairo

# اختياري: مع npm start (HTTPS) يُشغّل HTTP بدون شهادة على PORT+1 (مثلاً 3001).
# عطّله: HTTP_EXTRA_PORT=0

# للاستضافة الحقيقية (Let's Encrypt أو شهادة السيرفر):
# SSL_CERT_PATH=/etc/letsencrypt/live/yourdomain.com/fullchain.pem
# SSL_KEY_PATH=/etc/letsencrypt/live/yourdomain.com/privkey.pem
# PORT=443
# أو اترك Node على 3000 وضع Nginx أمامه يعمل SSL ويوجّه للـ proxy.

# --- Render.com ---
# استخدم render.yaml أو أنشئ Web Service يدوياً: Build = npm install ، Start = npm start
# عيّن USE_HTTPS=0 و HTTP_EXTRA_PORT=0 (Render يوفّر HTTPS من عنده).
# بعد النشر: Shell → PUBLIC_URL="https://YOUR.onrender.com" npm run seed
#
# لو عندك QR مطبوعة من manifest قديم: عيّن DISABLE_AUTO_SEED=1 وارفع data/app.db + manifest
# من نفس الـ seed، وإلا كل إعادة نشر بدون قرص دائم تعيد توليد رموز جديدة ويبقى المسح «غير معروف».

# DISABLE_AUTO_SEED=1
