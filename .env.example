# انسخ الملف إلى .env وعدّل القيم
DASHBOARD_USER=admin
DASHBOARD_PASS=ضع_كلمة_سر_قوية_هنا

# اختياري: مع npm start (HTTPS) يُشغّل HTTP بدون شهادة على PORT+1 (مثلاً 3001).
# عطّله: HTTP_EXTRA_PORT=0

# للاستضافة الحقيقية (Let's Encrypt أو شهادة السيرفر):
# SSL_CERT_PATH=/etc/letsencrypt/live/yourdomain.com/fullchain.pem
# SSL_KEY_PATH=/etc/letsencrypt/live/yourdomain.com/privkey.pem
# PORT=443
# أو اترك Node على 3000 وضع Nginx أمامه يعمل SSL ويوجّه للـ proxy.

# بعد رفع المشروع: على السيرفر نفّذ npm install ثم npm run seed مع:
# PUBLIC_URL=https://yourdomain.com

# --- Render.com ---
# استخدم render.yaml أو أنشئ Web Service يدوياً: Build = npm install ، Start = npm start
# عيّن USE_HTTPS=0 و HTTP_EXTRA_PORT=0 (Render يوفّر HTTPS من عنده).
# بعد النشر: Shell → PUBLIC_URL="https://YOUR.onrender.com" npm run seed
